{
  "manifest_version": 3,
  "name": "Transcript",
  "description": "Transcribe audio with Deepgram.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/chrome-transcript.png",
    "32": "icons/chrome-transcript.png",
    "48": "icons/chrome-transcript.png",
    "128": "icons/chrome-transcript.png"
  },
  "action": {
    "default_title": "Transcript",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/chrome-transcript.png",
      "32": "icons/chrome-transcript.png",
      "48": "icons/chrome-transcript.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "sidePanel",
    "tabCapture",
    "offscreen",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://api.deepgram.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/chrome-transcript.png", "audio-worklet.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
